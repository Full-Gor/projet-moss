{% extends 'base.html.twig' %}

{% block title %}Histoire - MossAir{% endblock %}
{% block meta_description %}Découvrez les bienfaits de la mousse pour purifier l'air : réduction des poussières fines, COV et CO2. La mousse, un organisme ancien aux capacités de filtration exceptionnelles.{% endblock %}
{% block meta_keywords %}mousse purificateur, bienfaits mousse, filtration air naturelle, poussières fines, COV, écosystème mousse{% endblock %}

{% block body %}
	<style>
		.youtube-iframe {
			border-radius: 24px;
			overflow: hidden;
			box-shadow: 0 4px 16px rgba(0, 0, 0, 0.10);
			border: none;
			display: block;
			margin: 0 auto;
		}
		.youtube-iframe.large {
			width: 1100px !important;
			height: 618px !important;
			max-width: 100%;
		}

		/* Responsive pour la page Histoire */
		@media (max-width: 992px) {
			.youtube-iframe.large {
				width: 90vw !important;
				height: 50vw !important;
			}

			.header-overlay-text {
				font-size: 1.6rem !important;
				padding: 0 1rem;
			}

			.benefits-text h2 {
				font-size: 1.8rem;
			}

			.benefits-text p {
				font-size: 1rem;
			}
		}

		@media (max-width: 768px) {
			.youtube-iframe {
				width: 90vw !important;
				height: 50vw !important;
				border-radius: 16px;
			}

			.youtube-iframe.large {
				width: 95vw !important;
				height: 53vw !important;
			}

			.header-overlay-text {
				font-size: 1.3rem !important;
				line-height: 1.4 !important;
			}

			.benefits-text {
				padding: 1rem;
			}

			.benefits-text h2 {
				font-size: 1.5rem;
			}

			.benefits-text p {
				font-size: 0.95rem;
			}

			.final-rectangle h3 {
				font-size: 1.5rem;
			}

			.final-rectangle p {
				font-size: 1rem;
			}
		}

		@media (max-width: 480px) {
			.youtube-iframe {
				width: 95vw !important;
				height: 53vw !important;
				border-radius: 12px;
			}

			.header-overlay-text {
				font-size: 1rem !important;
				padding: 0 0.5rem;
			}

			.benefits-text h2 {
				font-size: 1.3rem;
			}

			.benefits-text p {
				font-size: 0.9rem;
			}

			.final-rectangle h3 {
				font-size: 1.3rem;
			}

			.final-rectangle p {
				font-size: 0.9rem;
			}
		}
	</style>
	<div
		class="histoire-page">
		<!-- Video Header -->
		<div class="video-header" style="position:relative;">
			<iframe src="https://www.youtube.com/embed/KwRd0TRkAyc?autoplay=1&mute=1&loop=1&playlist=KwRd0TRkAyc&playsinline=1&controls=0&showinfo=0&rel=0"
				style="width:100%;height:100%;border:none;" allow="autoplay" allowfullscreen></iframe>
			<div class="header-overlay-text" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:white;font-size:2.2rem;text-align:center;text-shadow:0 2px 8px #222;max-width:90vw;z-index:5;line-height:1.2;">
				Libérez la puissance de la nature avec la mousse.<br>
				Purifiez votre air, augmentez l'humidité, créez un environnement paisible.<br>
				Sublimez votre espace avec la beauté et les bienfaits de la mousse.
			</div>
		</div>

		<!-- Video centrée avec carrés animés -->
		<section class="stats-section" style="position:relative;">
			<div style="display:flex; justify-content:center; align-items:center; flex-direction:column;">
				<iframe class="youtube-iframe large" style="margin-bottom:1rem;"
				src="https://www.youtube.com/embed/4bHUsy74Fss?start=15&mute=1&playsinline=1&rel=0"
				allow="autoplay" allowfullscreen></iframe>
				<div class="stats-overlay">
					<div class="stat-box">-90% poussières fines</div>
					<div class="stat-box">-60% COV</div>
					<div class="stat-box">-40% dioxyde de carbone</div>
				</div>
			</div>
		</section>

		<!-- Section avec video carrée et texte -->
		<section class="benefits-section">
			<iframe class="youtube-iframe" style="display:block; margin:0 auto 1rem auto; width:560px; height:315px;"
				src="https://www.youtube.com/embed/4bHUsy74Fss?start=66&mute=1&playsinline=1&rel=0"
				allow="autoplay" allowfullscreen></iframe>
			<div class="benefits-text">
				<h2>Les bénéfices de la mousse dans l'écosystème</h2>
				<p>La mousse est l'un des organismes les plus anciens et les plus résilients de notre planète. Elle possède des capacités de filtration exceptionnelles, absorbant les particules fines et les polluants tout en produisant de l'oxygène. Dans nos espaces urbains, elle agit comme un poumon vert miniature, créant un microclimat plus sain et plus agréable.</p>
			</div>
			<iframe class="youtube-iframe" style="display:block; margin:1rem auto 0 auto; width:560px; height:315px;"
				src="https://www.youtube.com/embed/4bHUsy74Fss?start=92&mute=1&playsinline=1&rel=0"
				allow="autoplay" allowfullscreen></iframe>
		</section>

		<!-- Video 80% largeur -->
		<section class="wide-video-section">
			<video autoplay muted loop class="wide-video">
				<source src="{{ asset('videos/process-video.mp4') }}" type="video/mp4">
			</video>
		</section>

		<!-- Section finale avec video carrée et rectangle -->
		<section class="final-section">
			<video autoplay muted loop class="final-square-video">
				<source src="{{ asset('videos/final-video.mp4') }}" type="video/mp4">
			</video>
			<div class="final-rectangle">
				<h3>Rejoignez la révolution verte</h3>
				<p>Transformez votre espace avec Moss Air</p>
			</div>
		</section>
	</div>
	{# Les vidéos YouTube sont intégrées avec des iframes simples ci-dessus #}

{% endblock %}
