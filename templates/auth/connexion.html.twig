{% extends 'base.html.twig' %}

{% block body %}
	<div class="container mt-5 mb-5">
		<div class="row justify-content-center">
			<div class="col-md-5">
				<div class="card auth-card">
					<div class="card-body">

						{# Onglets Connexion / Inscription #}
						<div class="auth-tabs">
							<button class="auth-tab active" id="btn-login" onclick="showTab('login')">
								<i class="fas fa-sign-in-alt"></i> Connexion
							</button>
							<button class="auth-tab" id="btn-register" onclick="showTab('register')">
								<i class="fas fa-user-plus"></i> Inscription
							</button>
						</div>

						{# Message d'erreur #}
						{% if error %}
							<div class="alert alert-danger mt-3">{{ error }}</div>
						{% endif %}

						{# ===== FORMULAIRE CONNEXION (Symfony FormType) ===== #}
						<div id="form-login" class="auth-form">
							{{ form_start(loginForm, {'attr': {'class': 'mt-3'}}) }}
								{{ form_row(loginForm.prenom) }}
								{{ form_row(loginForm.password) }}
								<div class="mt-3">
									{{ form_widget(loginForm.submit, {'attr': {'class': 'btn btn-primary w-100'}}) }}
								</div>
							{{ form_end(loginForm) }}
						</div>

						{# ===== FORMULAIRE INSCRIPTION (Symfony FormType) ===== #}
						<div id="form-register" class="auth-form" style="display:none;">
							{{ form_start(registerForm, {'attr': {'class': 'mt-3'}}) }}
								<div class="row">
									<div class="col-6">
										{{ form_row(registerForm.prenom) }}
									</div>
									<div class="col-6">
										{{ form_row(registerForm.nom) }}
									</div>
								</div>
								{{ form_row(registerForm.email) }}
								{{ form_row(registerForm.password.first) }}
								{{ form_row(registerForm.password.second) }}
								<div class="mt-3">
									{{ form_widget(registerForm.submit, {'attr': {'class': 'btn btn-success w-100'}}) }}
								</div>
							{{ form_end(registerForm) }}
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>

	<style>
		.auth-card {
			border: none;
			box-shadow: 0 4px 20px rgba(0,0,0,0.08);
			border-radius: 12px;
		}
		.auth-card .card-body {
			padding: 2rem;
		}
		.auth-tabs {
			display: flex;
			border-bottom: 2px solid #e9ecef;
			margin-bottom: 1rem;
		}
		.auth-tab {
			flex: 1;
			background: none;
			border: none;
			padding: 0.8rem;
			font-size: 1rem;
			font-weight: 600;
			color: #999;
			cursor: pointer;
			border-bottom: 3px solid transparent;
			transition: all 0.3s;
		}
		.auth-tab:hover { color: #4a7c59; }
		.auth-tab.active {
			color: #4a7c59;
			border-bottom-color: #4a7c59;
		}
		.btn-primary {
			background: #4a7c59;
			border: none;
			padding: 0.7rem;
			border-radius: 8px;
			font-weight: 600;
		}
		.btn-primary:hover { background: #3d6b4a; }
		.btn-success {
			background: #28a745;
			border: none;
			padding: 0.7rem;
			border-radius: 8px;
			font-weight: 600;
		}
		.btn-success:hover { background: #218838; }
	</style>

	<script>
		function showTab(tab) {
			document.getElementById('form-login').style.display = tab === 'login' ? 'block' : 'none';
			document.getElementById('form-register').style.display = tab === 'register' ? 'block' : 'none';
			document.getElementById('btn-login').classList.toggle('active', tab === 'login');
			document.getElementById('btn-register').classList.toggle('active', tab === 'register');
		}
	</script>
{% endblock %}
